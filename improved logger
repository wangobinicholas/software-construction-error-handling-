import requests
import logging

# Configure basic logging logic
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
logger = logging.getLogger(__name__)

# -------------------------------------------------------------
# Original code piece 
# -------------------------------------------------------------
def bad_fetch_user_company(user_id):
    try:
        response = requests.get(f"https://api.github.com/users/{user_id}")
        data = response.json()
        return data['company']
    except Exception as e:
        # BAD: Catches everything, gives no context, swallows the real traceback
        print("Error!")
        return None


# -------------------------------------------------------------
# 2. THE REFACTORED "AFTER" CODE (Improved Strategies & Logging)
# -------------------------------------------------------------
def good_fetch_user_company(user_id):
    url = f"https://api.github.com/users/{user_id}"
    logger.info(f"Attempting to fetch user data for user_id: {user_id}")
    
    try:
        response = requests.get(url, timeout=5.0)
        
        # Raise an exception for HTTP error codes (404, 500, etc.)
        response.raise_for_status()
        
        data = response.json()
        company = data['company']

        if not company:
            logger.info(f"User '{user_id}' found, but has no company listed.")
        
        return company

    # TARGETED FIX 1: Handle HTTP Errors specifically (404 Not Found, 403 Rate Limit)
    except requests.exceptions.HTTPError as e:
        # Human Reasoning: Differentiate between a user not existing vs our app being blocked
        if e.response.status_code == 404:
            logger.warning(f"User ID '{user_id}' does not exist on GitHub (HTTP 404).")
        elif e.response.status_code == 403:
            logger.critical(f"GitHub API Rate limit exceeded while fetching '{user_id}'. Consider using an API token.")
        else:
            logger.error(f"HTTP Error {e.response.status_code} occurred fetching '{user_id}': {e}")
        return None

    # TARGETED FIX 2: Handle generic Network/Connection issues
    except requests.exceptions.RequestException as e:
        logger.error(f"Network error while connecting to '{url}': {e}")
        return None

    # TARGETED FIX 3: Handle Malformed Data or missing keys
    except requests.exceptions.JSONDecodeError:
        logger.error(f"Failed to parse JSON response for user_id '{user_id}'. The API might be down or returning HTML.")
        return None
        
    except KeyError as e:
        logger.error(f"Unexpected JSON structure for user_id '{user_id}'. The key '{e}' is missing from the response payload.")
        return None

    # TARGETED FIX 4: Catch-All fallback, but LOG THE TRACEBACK so developers can patch it later
    except Exception as e:
        logger.exception(f"An unexpected critical error occurred processing user_id '{user_id}'.")
        return None


if __name__ == "__main__":
    print("--- Running Bad Function ---")
    # Will just print "Error!" for a non-existent user instead of explaining what happened.
    bad_fetch_user_company("this_user_definitely_does_not_exist_12345") 
    
    print("\n--- Running Improved Function ---")
    # Will emit a clean, contextual, human-reasoned Warning log.
    good_fetch_user_company("this_user_definitely_does_not_exist_12345")
